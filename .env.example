# LLM Token Manager 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 必填配置 ====================

# JWT 签名密钥（生产环境必须更改为随机字符串）
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# AES-256 加密密钥（用于供应商 Key 加密，必须是 32 字符）
# 生成方法: openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=your-encryption-key-32-characters!!

# ==================== 访问配置 ====================

# 服务端口（默认 8080）
LTM_PORT=8080

# 基础路径（默认 /ltm，访问地址为 http://IP:端口/ltm/）
# 如果部署在根路径，设置为空字符串 ""
LTM_BASE_PATH=/ltm

# ==================== 数据库配置 ====================

# PostgreSQL 密码（生产环境请更改）
POSTGRES_PASSWORD=postgres

# 数据库连接（Docker 内部使用，一般不需要修改）
DATABASE_URL=postgresql://postgres:postgres@db:5432/llm_manager

# ==================== 应用配置 ====================

# 用户注册模式: open (开放注册) / invite (仅邀请)
REGISTRATION_MODE=open

# 允许注册的邮箱域名（多个用逗号分隔，留空表示不限制）
ALLOWED_EMAIL_DOMAINS=

# ==================== 默认额度配置 ====================

# 默认月度额度 (USD)
DEFAULT_MONTHLY_QUOTA_USD=10.00

# 默认每分钟请求限制
DEFAULT_RPM_LIMIT=30

# 默认每用户最大 Key 数量
DEFAULT_MAX_KEYS=5
