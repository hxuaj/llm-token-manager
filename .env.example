# LLM Token Manager 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_manager

# JWT 签名密钥（生产环境必须更改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# AES-256 加密密钥（用于供应商 Key 加密，必须是 32 字符）
ENCRYPTION_KEY=your-encryption-key-32-characters!!

# 测试模式（pytest 会自动设置）
TESTING=false

# 用户注册配置
REGISTRATION_MODE=open
ALLOWED_EMAIL_DOMAINS=yourcompany.com

# 默认额度配置
DEFAULT_MONTHLY_QUOTA_USD=10.00
DEFAULT_RPM_LIMIT=30
DEFAULT_MAX_KEYS=5
